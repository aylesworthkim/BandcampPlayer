# Supabase — copy this file to .env.local and fill in your project's values.
# Found in the Supabase dashboard under Project Settings → API.
# Both are safe to expose to the browser (the anon key is protected by Row Level
# Security). Never commit .env.local or any real service_role/secret keys.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
